{
  "name": "bazaar-web",
  "version": "0.1.0",
  "description": "Bazaar accounting PWA — Vue 3 + shadcn-vue + Persian/RTL, offline-first, Capacitor-ready",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
    "gen:api": "openapi-typescript http://localhost:5108/swagger/v1/swagger.json -o src/types/api.d.ts",
    "gen:icons": "pwa-assets-generator --preset minimal-2023 public/icons/icon.svg",
    "cap:sync": "cap sync android",
    "cap:android": "cap run android"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.3",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@lucide/vue": "^1.17.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dexie": "^4.4.2",
    "jalaliday": "^3.1.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.10",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vazirmatn": "^33.0.3",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vue-input-otp": "^0.3.2",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "vue3-persian-datetime-picker": "^1.2.2",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.3",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.2.8",
    "workbox-build": "^7.4.1"
  }
}
